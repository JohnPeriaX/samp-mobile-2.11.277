# Normalize text files
* text=auto

# Source files use LF
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.hh text eol=lf
*.java text eol=lf
*.kt text eol=lf
*.gradle text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Windows scripts use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.so binary
*.a binary
*.jar binary
*.zip binary
*.apk binary
*.aab binary
